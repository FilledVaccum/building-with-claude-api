# Auto detect text files and normalize line endings to LF
* text=auto eol=lf

# Jupyter notebooks
*.ipynb text eol=lf

# Python files
*.py text eol=lf

# Markdown
*.md text eol=lf

# YAML
*.yml text eol=lf
*.yaml text eol=lf

# JSON
*.json text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.pdf binary
